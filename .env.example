# ============================================
# SAI - Variables de Entorno para Producción
# ============================================
# Copiar este archivo a .env y ajustar los valores

# ============================================
# BASE DE DATOS
# ============================================
POSTGRES_USER=sai_user
POSTGRES_PASSWORD=CHANGE_ME_secure_password_123!

# ============================================
# JWT - Autenticación
# ============================================
# Generar secretos seguros con: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_change_this_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# MINIO - Almacenamiento de Archivos
# ============================================
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=CHANGE_ME_minio_secure_password

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:3002

# ============================================
# API URL (para el frontend)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. Cambiar TODOS los valores "CHANGE_ME" antes de producción
# 2. Generar secretos seguros con: openssl rand -base64 32
# 3. En producción, usar HTTPS y dominios reales
# 4. No commitear este archivo al repositorio
